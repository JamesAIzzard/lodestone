{
  "name": "lodestone",
  "productName": "Lodestone",
  "version": "1.1.0",
  "description": "Local semantic search over your files via MCP",
  "main": ".vite/build/main.js",
  "private": true,
  "scripts": {
    "start": "electron-forge start",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "publish": "electron-forge publish",
    "lint": "eslint --ext .ts,.tsx .",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\" \"*.{ts,json,html}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "reset-data": "node scripts/reset-data.mjs",
    "deploy:worker": "cd worker && npx wrangler deploy",
    "deploy:worker:dev": "cd worker && npx wrangler deploy --env dev"
  },
  "keywords": [],
  "author": {
    "name": "James Izzard",
    "email": "jamesaizzard@gmail.com"
  },
  "license": "MIT",
