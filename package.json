{
  "name": "lodestone",
  "productName": "Lodestone",
  "version": "1.4.0",
  "description": "Local semantic search over your files via MCP",
  "main": ".vite/build/main.js",
  "private": true,
  "scripts": {
    "typecheck": "tsc --noEmit",
    "native:electron": "electron-rebuild -f -w better-sqlite3,sqlite-vec",
    "native:node": "npm rebuild better-sqlite3 sqlite-vec",
    "prestart": "npm run native:electron",
    "start": "electron-forge start",
    "pretest": "npm run native:node",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "publish": "electron-forge publish",
    "lint": "eslint --ext .ts,.tsx .",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\" \"*.{ts,json,html}\"",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [],
  "author": {
    "name": "James Izzard",
    "email": "jamesaizzard@gmail.com"
  },
  "license": "MIT",
  "devDependencies": {
    "@electron-forge/cli": "^7.11.1",
    "@electron-forge/maker-deb": "^7.11.1",
    "@electron-forge/maker-rpm": "^7.11.1",
    "@electron-forge/maker-squirrel": "^7.11.1",
    "@electron-forge/maker-zip": "^7.11.1",
    "@electron-forge/plugin-auto-unpack-natives": "^7.11.1",
    "@electron-forge/plugin-fuses": "^7.11.1",
    "@electron-forge/plugin-vite": "^7.11.1",
    "@electron/fuses": "^1.8.0",
    "@tailwindcss/postcss": "^4.2.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/diff": "^7.0.2",
    "@types/electron-squirrel-startup": "^1.0.2",
    "@types/lodash.throttle": "^4.1.9",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^5.62.0",
    "@typescript-eslint/parser": "^5.62.0",
    "electron": "40.6.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^3.6.1",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "postcss": "^8.5.6",
    "prettier": "^3.8.1",
    "sass": "^1.97.3",
    "sass-embedded": "^1.97.3",
    "tailwindcss": "^4.2.0",
    "typescript": "^5.9.3",
    "vite": "^5.4.21",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@huggingface/transformers": "^3.8.1",
    "@modelcontextprotocol/sdk": "^1.26.0",
    "@radix-ui/react-tooltip": "^1.2.8",
    "better-sqlite3": "^12.6.2",
    "chokidar": "^5.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "diff": "^8.0.3",
    "electron-squirrel-startup": "^1.0.1",
    "gray-matter": "^4.0.3",
    "lodash.throttle": "^4.1.1",
    "lucide-react": "^0.575.0",
    "mdast-util-to-string": "^4.0.0",
    "pdfjs-dist": "^5.4.624",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hotkeys-hook": "^5.2.4",
    "react-router-dom": "^7.13.0",
    "remark-parse": "^11.0.0",
    "smol-toml": "^1.6.0",
    "sqlite-vec": "^0.1.7-alpha.10",
    "tailwind-merge": "^3.5.0",
    "trash": "^10.1.0",
    "tree-sitter-wasms": "^0.1.13",
    "unified": "^11.0.5",
    "web-tree-sitter": "^0.20.8",
    "zod": "^4.3.6"
  }
}
